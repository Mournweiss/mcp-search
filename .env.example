# MCP Search Configuration

# Project
LOG_LEVEL=info
LOG_FORMAT=json
PROJECT_NAME=mcp-search

# SearxNG
REGISTRY_SEARXNG=docker.io/searxng/searxng
VERSION_SEARXNG=latest
SEARXNG_PORT=8080
SEARXNG_HOST=[::]
SEARXNG_SECRET_KEY=your-secret-here
SEARXNG_DEBUG=false
SEARXNG_INSTANCE_NAME=MCP_Search_Instance
SEARXNG_USE_DEFAULT_SETTINGS=true
SEARXNG_SETTINGS_PATH=/etc/searxng/settings.yml
SEARXNG_LIMITER_ENABLED=true
GRANIAN_WORKERS=2
GRANIAN_WORKER_THREADS=4
GRANIAN_LOG_LEVEL=warning
FORCE_OWNERSHIP=true

# Redis
REGISTRY_REDIS=docker.io/redis
VERSION_REDIS=7-alpine
REDIS_PORT=6379
REDIS_DB=0

# NUQ PostgreSQL
REGISTRY_POSTGRES=ghcr.io/firecrawl/nuq-postgres
VERSION_POSTGRES=latest
POSTGRES_USER=firecrawl
POSTGRES_PASSWORD=your-secret-here
POSTGRES_DB=firecrawl
POSTGRES_PORT=5432

# Firecrawl
REGISTRY_FIRECRAWL=ghcr.io/firecrawl/firecrawl
VERSION_FIRECRAWL=latest
FIRECRAWL_PORT=3000
FIRECRAWL_HOST=0.0.0.0
USE_DB_AUTHENTICATION=false
BULL_AUTH_KEY=your-secret-here
TEST_API_KEY=
SEARXNG_ENGINES=google,duckduckgo,bing
SEARXNG_CATEGORIES=general,it,science
PROXY_SERVER=
PROXY_USERNAME=
PROXY_PASSWORD=
OPENAI_API_KEY=
OPENAI_BASE_URL=
MODEL_NAME=
OLLAMA_BASE_URL=
MODEL_EMBEDDING_NAME=
MAX_CPU=0.8
MAX_RAM=0.8
SLACK_WEBHOOK_URL=
POSTHOG_API_KEY=
POSTHOG_HOST=https://app.posthog.com
ALLOW_LOCAL_WEBHOOKS=false

# MCP Server
REGISTRY_MCP=docker.io/library/python
VERSION_MCP=3.14-slim
MCP_PORT=8000
MCP_TRANSPORT=http
MCP_HTTP_HOST=0.0.0.0
REQUEST_TIMEOUT=30
CONNECT_TIMEOUT=10
REQUEST_RETRY_COUNT=3
REQUEST_RETRY_DELAY=1
MAX_CONCURRENT_REQUESTS=10
MAX_QUEUE_SIZE=100
MCP_API_KEY=
ALLOWED_ORIGINS=*
ENABLE_RATE_LIMITING=true
RATE_LIMIT_REQUESTS=60
RATE_LIMIT_WINDOW=60
LOG_FILE_PATH=
ENABLE_REQUEST_LOGGING=true
ENABLE_RESPONSE_LOGGING=false
ENABLE_WEB_SEARCH=true
ENABLE_WEB_CRAWL=true
ENABLE_CONTENT_EXTRACT=true
REDIS_CACHE_TTL=3600
DEFAULT_MAX_RESULTS=10
MAX_SEARCH_RESULTS=50

# Playwright
REGISTRY_PLAYWRIGHT=mcr.microsoft.com/playwright
VERSION_PLAYWRIGHT=v1.58.2-noble
PLAYWRIGHT_NPM_VERSION=1.58.2
PLAYWRIGHT_PORT=3000
PLAYWRIGHT_HOST=0.0.0.0
PLAYWRIGHT_BROWSERS_PATH=./services/playwright/ms-playwright
PLAYWRIGHT_SKIP_BROWSER_DOWNLOAD=0
PLAYWRIGHT_CHROMIUM_ENABLE_SANDBOX=false
PLAYWRIGHT_FIREFOX_ENABLE_SANDBOX=false
PLAYWRIGHT_WEBKIT_ENABLE_SANDBOX=false
PLAYWRIGHT_RUN_AS_USER=pwuser
PLAYWRIGHT_SECCOMP_PROFILE=./services/playwright/seccomp_profile.json
PLAYWRIGHT_IPC_MODE=host
PLAYWRIGHT_DEBUG=pw:api
PLAYWRIGHT_LOG_LEVEL=info
PLAYWRIGHT_PROXY_SERVER=
PLAYWRIGHT_PROXY_USERNAME=
PLAYWRIGHT_PROXY_PASSWORD=
# PLAYWRIGHT_CPU_LIMIT=2
# PLAYWRIGHT_MEMORY_LIMIT=2G

# RabbitMQ
REGISTRY_RABBITMQ=docker.io/rabbitmq
VERSION_RABBITMQ=3-management
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672
RABBITMQ_DIST_PORT=25672
RABBITMQ_DEFAULT_USER=firecrawl
RABBITMQ_DEFAULT_PASS=your-secret-here
RABBITMQ_DEFAULT_VHOST=/
RABBITMQ_NODENAME=rabbit@rabbitmq
RABBITMQ_SERVER_ADDITIONAL_ERL_ARGS=
RABBITMQ_PLUGINS=rabbitmq_management
RABBITMQ_LOG_BASE=/var/log/rabbitmq
RABBITMQ_MNESIA_BASE=/var/lib/rabbitmq/mnesia